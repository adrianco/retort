%%% rebar3 build configuration for the Brazilian Soccer MCP server.
%%%
%%% The project is a self-contained OTP application with no third-party
%%% dependencies: JSON is handled by the OTP 27+ built-in `json` module and
%%% everything else (CSV parsing, the knowledge graph, the MCP/JSON-RPC stdio
%%% loop) is implemented in plain Erlang under src/.
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

%% Build a standalone `bsoccer` escript that speaks the MCP stdio protocol.
{escript_name, bsoccer}.
{escript_main_app, bsoccer}.
{escript_emu_args, "%%! -escript main bsoccer_cli +sbtu +A1\n"}.

{eunit_opts, [verbose]}.

{profiles, [{test, [{erl_opts, [nowarn_export_all]}]}]}.
