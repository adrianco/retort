{erl_opts, [debug_info]}.
{deps, [
    {thoas, "1.2.1"}
]}.

{shell, [
    {apps, [brazilian_soccer_mcp]}
]}.

{escript_main_app, brazilian_soccer_mcp}.
{escript_name, "brazilian_soccer_mcp"}.
{escript_incl_apps, [thoas]}.
{escript_emu_args, "%%! -smp enable +scl false\n"}.

{profiles, [
    {test, [
        {extra_src_dirs, ["test"]},
        {deps, []}
    ]}
]}.
