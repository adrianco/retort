%%% ===================================================================
%%% Brazilian Soccer MCP Server - rebar3 build configuration
%%%
%%% Context: Build/test configuration for an MCP (Model Context Protocol)
%%% server, written in Erlang/OTP, that answers natural-language style
%%% questions about Brazilian soccer (matches, teams, players,
%%% competitions and statistics) over a corpus of Kaggle CSV datasets.
%%%
%%% No third-party dependencies are required: JSON encoding/decoding uses
%%% the OTP `json' module (OTP 27+). EUnit drives the executable
%%% acceptance tests that specify the behaviour of the MCP tools.
%%% ===================================================================
{erl_opts, [debug_info]}.

{deps, []}.

{shell, [{apps, [bsoccer]}]}.

{eunit_opts, [verbose]}.

{escript_main_app, bsoccer}.
{escript_name, "bsoccer-mcp"}.
{escript_emu_args, "%%! -escript main bsoccer_stdio +pc unicode\n"}.

{dialyzer, [{warnings, [no_return, error_handling]}]}.
