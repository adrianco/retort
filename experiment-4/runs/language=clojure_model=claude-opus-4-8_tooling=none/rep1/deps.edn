;; =============================================================================
;; Brazilian Soccer MCP Server - Project Dependencies
;; =============================================================================
;;
;; CONTEXT
;;   deps.edn for the Brazilian Soccer MCP (Model Context Protocol) server.
;;   The server loads six Kaggle CSV datasets (matches + FIFA players) into an
;;   in-memory knowledge graph and exposes natural-language-friendly query
;;   tools over the MCP stdio (JSON-RPC 2.0) transport.
;;
;;   We deliberately use an in-memory graph (rather than a networked store such
;;   as Neo4j) so the server and its full BDD test-suite run with zero external
;;   infrastructure. The data layer still models the same graph entities -
;;   Teams, Matches, Competitions and Players - and the relationships between
;;   them.
;;
;; DEPENDENCIES
;;   org.clojure/clojure   - language runtime
;;   org.clojure/data.csv  - RFC-4180 CSV parsing (handles quoting/UTF-8)
;;   cheshire              - fast JSON encode/decode for the JSON-RPC transport
;;
;; ALIASES
;;   :run   - start the MCP server on stdio  (clojure -M:run)
;;   :test  - run the clojure.test BDD suite (clojure -M:test)
;; =============================================================================
{:paths ["src" "resources"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.csv  {:mvn/version "1.1.0"}
        cheshire/cheshire     {:mvn/version "5.13.0"}}

 :aliases
 {:run  {:main-opts ["-m" "brazilian-soccer.main"]}

  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]
         :exec-fn     cognitect.test-runner.api/test}}}
