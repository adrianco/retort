{:paths ["src" "resources"]
 :deps {org.clojure/clojure       {:mvn/version "1.12.0"}
        org.clojure/data.csv      {:mvn/version "1.1.0"}
        cheshire/cheshire         {:mvn/version "5.13.0"}}
 :aliases
 {;; Run the MCP server over stdio: clojure -M:server
  :server {:main-opts ["-m" "brazilian-soccer.main"]}

  ;; Answer 20+ sample questions through the MCP tools: clojure -M:demo
  :demo {:main-opts ["-m" "brazilian-soccer.demo"]}

  ;; Run the test suite: clojure -M:test
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}}}
