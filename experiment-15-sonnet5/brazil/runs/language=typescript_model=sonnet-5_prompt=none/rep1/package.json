{
  "name": "brazilian-soccer-mcp",
  "version": "1.0.0",
  "description": "MCP server providing a knowledge graph interface for Brazilian soccer data (matches, teams, players, competitions).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brazilian-soccer-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csv-parse": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
