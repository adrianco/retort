{
  "name": "brazilian-soccer-mcp",
  "version": "1.0.0",
  "description": "MCP server providing a knowledge-graph-style interface over Brazilian soccer match and player datasets",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
