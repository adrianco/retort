{
  "name": "brazilian-soccer-mcp",
  "version": "1.0.0",
  "description": "MCP server providing a knowledge-graph-style query interface over Brazilian soccer datasets (matches, teams, players, competitions, statistics).",
  "type": "module",
  "bin": {
    "brazilian-soccer-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "brazilian-soccer",
    "football",
    "knowledge-graph"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
