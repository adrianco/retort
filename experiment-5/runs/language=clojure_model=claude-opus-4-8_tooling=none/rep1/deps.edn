;; =============================================================================
;; deps.edn — Brazilian Soccer MCP Server (Clojure)
;; -----------------------------------------------------------------------------
;; Dependencies are intentionally pure-JVM / pure-Clojure so the project builds
;; and runs without any native libraries or external database:
;;   - org.clojure/data.csv   : streaming CSV reader for the Kaggle datasets
;;   - org.clojure/data.json  : JSON-RPC encode/decode for the MCP stdio loop
;;
;; Aliases:
;;   (default)  : `clojure -M -m soccer.main`  -> start the MCP stdio server
;;   :test      : `clojure -M:test`            -> run the BDD (GWT) test suite
;; =============================================================================
{:paths ["src" "data"]
 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.csv  {:mvn/version "1.1.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}}
 :aliases
 {:run  {:main-opts ["-m" "soccer.main"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
