{erl_opts, [debug_info]}.
{deps, [
    {jsx, "3.1.0"}
]}.
{shell, [
    {apps, [br_soccer_mcp]}
]}.
{escript_main_app, br_soccer_mcp}.
{escript_name, br_soccer_mcp}.
{escript_emu_args, "%%! -smp enable\n"}.
{provider_hooks, [
    {post, [{compile, escriptize}]}
]}.
{profiles, [
    {test, [
        {erl_opts, [debug_info, {d, 'TEST'}]},
        {deps, []}
    ]}
]}.
