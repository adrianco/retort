;; =============================================================================
;; Brazilian Soccer MCP Server - Project dependencies
;; -----------------------------------------------------------------------------
;; Clojure tools.deps project configuration.
;;
;; Aliases:
;;   (default)  -> run the MCP stdio server:  clojure -M -m brazilian-soccer.main
;;   :test      -> run the test suite:        clojure -M:test
;;   :repl      -> interactive REPL with src + test on the classpath
;;
;; Runtime deps:
;;   data.csv  - RFC-4180 CSV reader for the Kaggle datasets
;;   data.json - JSON-RPC (de)serialisation for the MCP protocol
;; =============================================================================
{:paths ["src" "resources"]
 :deps  {org.clojure/clojure   {:mvn/version "1.12.0"}
         org.clojure/data.csv  {:mvn/version "1.1.0"}
         org.clojure/data.json {:mvn/version "2.5.0"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}
  :repl {:extra-paths ["test"]}}}
