{
  "name": "brazilian-soccer-mcp",
  "version": "1.0.0",
  "description": "MCP server providing a knowledge interface for Brazilian soccer data (matches, teams, players, competitions).",
  "type": "module",
  "bin": {
    "brazilian-soccer-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "soccer",
    "football",
    "brazil"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "csv-parse": "^5.5.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
