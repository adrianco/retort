{erl_opts, [debug_info]}.

{deps, [
    {cowboy, "2.12.0"}
]}.

{relx, [
    {release, {book_api, "0.1.0"}, [book_api, sasl]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {apps, [book_api]}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.
