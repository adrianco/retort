{erl_first_files, [
    "src/bookapi_app.erl",
    "src/bookapi_sup.erl",
    "src/bookapi_db.erl",
    "src/bookapi_validator.erl",
    "src/bookapi_health_handler.erl",
    "src/bookapi_collection_handler.erl",
    "src/bookapi_item_handler.erl",
    "src/bookapi_server.erl"
]}.

{erl_opts, [debug_info, {d, 'TEST'}]}.

{deps, [cowboy]}.

{profiles, [{test, [{erl_opts, [debug_info]},
                    {src_dirs, ["src", "test"]}]}]}.

{cover_action, {cover, "cover.html"}}.
