;; =============================================================================
;; deps.edn — Brazilian Soccer MCP Server
;; -----------------------------------------------------------------------------
;; Context:
;;   Dependency / build configuration for the Brazilian Soccer MCP server.
;;   The server is implemented in pure Clojure with an in-memory knowledge
;;   graph loaded from the Kaggle CSV datasets in data/kaggle/. No external
;;   database (e.g. Neo4j) is required, which keeps the project self-contained
;;   and ensures `clojure -X:test` works in any environment.
;;
;; Runtime deps:
;;   org.clojure/data.csv  — RFC-4180 compliant CSV parsing (handles quoted
;;                           fields containing commas, used heavily by fifa_data)
;;   org.clojure/data.json — JSON read/write for the MCP JSON-RPC 2.0 protocol
;;
;; Usage:
;;   clojure -M:run            ; start the MCP server (JSON-RPC over stdio)
;;   clojure -X:test           ; run the BDD (Given/When/Then) test suite
;; =============================================================================
{:paths ["src" "data"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.csv  {:mvn/version "1.1.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}}

 :aliases
 {:run  {:main-opts ["-m" "brazilian-soccer.main"]}

  :test {:extra-paths ["test"]
         :exec-fn      brazilian-soccer.test-runner/run
         :main-opts    ["-m" "brazilian-soccer.test-runner"]}}}
