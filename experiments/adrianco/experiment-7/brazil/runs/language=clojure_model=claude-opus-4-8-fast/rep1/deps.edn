;; =============================================================================
;; deps.edn — Brazilian Soccer MCP Server
;; -----------------------------------------------------------------------------
;; Project: brazilian-soccer-mcp
;; Purpose: Dependency / alias configuration for a Model Context Protocol (MCP)
;;          server that answers natural-language questions about Brazilian
;;          soccer using the Kaggle datasets in data/kaggle/.
;;
;; Dependencies:
;;   - org.clojure/clojure   : language runtime
;;   - org.clojure/data.csv  : CSV parsing for the source datasets
;;   - org.clojure/data.json : JSON-RPC encode/decode for the MCP stdio protocol
;;
;; Aliases:
;;   :run   -> start the MCP server on stdio  (clojure -M:run)
;;   :test  -> run the BDD (Given/When/Then) test suite (clojure -M:test)
;; =============================================================================
{:paths ["src" "resources"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.csv  {:mvn/version "1.1.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}}

 :aliases
 {:run  {:main-opts ["-m" "soccer.mcp"]}

  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}}}
