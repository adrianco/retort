;; =============================================================================
;; deps.edn — Brazilian Soccer MCP Server
;; -----------------------------------------------------------------------------
;; Project dependencies and aliases.
;;
;; Aliases:
;;   (default) — runtime deps for the MCP server (`clojure -M -m brazilian-soccer.mcp-server`)
;;   :test     — clojure.test runner over the test/ directory
;;
;; Pure-Clojure/JVM deps only (data.csv, data.json) so the server has no native
;; or external service requirements: the knowledge graph is built in-memory from
;; the CSV files under data/kaggle/ at startup.
;; =============================================================================
{:paths ["src" "resources"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.csv  {:mvn/version "1.1.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   :main-opts   ["-m" "cognitect.test-runner"]
   :exec-fn     cognitect.test-runner.api/test}}}
