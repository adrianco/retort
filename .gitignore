# ── Experiment artifacts ──────────────────────────────────────────────────
# Strategy: TRACK the experiment definition + results — workspace.yaml,
# design*.csv, results.csv, reports/**, and retort.db — plus a curated
# allowlist of per-run source + metadata. IGNORE everything regenerable:
# build outputs, compiled binaries, dependency trees, caches, bundled
# datasets, lockfiles, DB sidecars, and execution logs.
#
# The per-run rules below are an allowlist (ignore all, then re-include known
# source/metadata extensions). This is task- and language-agnostic: a compiled
# binary named `app`, `server`, `main`, or `books` has no source extension, so
# it is ignored automatically — we never guess binary names and risk silently
# dropping a real source directory of the same name.
#
# NOTE: run playpens may contain a nested .git/. Git refuses to commit files
# from a directory that contains .git/ (it treats it as an embedded repo), so
# strip them before committing archives:
#   find experiment-*/runs -name .git -type d -prune -exec rm -rf {} +

# SQLite sidecars (the .db itself IS tracked, on purpose)
*.db-shm
*.db-wal

# Execution logs (shard-*.log, run.log)
experiment-*/*.log

# Per-run archives: ignore everything, then re-include structure + curated files
experiment-*/runs/**/*
!experiment-*/runs/**/
# Source the agent produced
!experiment-*/runs/**/*.py
!experiment-*/runs/**/*.go
!experiment-*/runs/**/*.rs
!experiment-*/runs/**/*.ts
!experiment-*/runs/**/*.tsx
!experiment-*/runs/**/*.js
!experiment-*/runs/**/*.jsx
!experiment-*/runs/**/*.java
!experiment-*/runs/**/*.clj
!experiment-*/runs/**/*.cljs
!experiment-*/runs/**/*.cljc
!experiment-*/runs/**/*.edn
# Build manifests (source of truth; lockfiles are deliberately NOT allowlisted)
!experiment-*/runs/**/go.mod
!experiment-*/runs/**/Cargo.toml
!experiment-*/runs/**/pom.xml
!experiment-*/runs/**/build.gradle
!experiment-*/runs/**/deps.edn
!experiment-*/runs/**/project.clj
!experiment-*/runs/**/pyproject.toml
!experiment-*/runs/**/requirements.txt
!experiment-*/runs/**/package.json
!experiment-*/runs/**/tsconfig.json
!experiment-*/runs/**/Makefile
# Docs + retort run metadata
!experiment-*/runs/**/*.md
!experiment-*/runs/**/*.txt
!experiment-*/runs/**/_meta.json
!experiment-*/runs/**/stack.json
!experiment-*/runs/**/assessment.json
!experiment-*/runs/**/findings.jsonl
# Hard-exclude heavy/regenerable trees LAST so they win over the re-includes
# above and no allowlisted file can leak out of a dependency/build dir.
experiment-*/runs/**/target/
experiment-*/runs/**/node_modules/
experiment-*/runs/**/build/
experiment-*/runs/**/dist/
experiment-*/runs/**/vendor/
experiment-*/runs/**/.gradle/
experiment-*/runs/**/__pycache__/
experiment-*/runs/**/.pytest_cache/
experiment-*/runs/**/.cpcache/
experiment-*/runs/**/.clj-kondo/
experiment-*/runs/**/.git/
experiment-*/runs/**/.venv/
experiment-*/runs/**/data/
experiment-*/runs/**/.idiomatic_cache.json
experiment-*/runs/**/.maintainability_cache.json

